{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Llama Launcher",
  "version": "0.1.0",
  "identifier": "com.vacio.llama-launcher",
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Llama Launcher",
        "width": 1100,
        "height": 780,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:6060",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  }
}
