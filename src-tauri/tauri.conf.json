{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Oh My Llama",
  "version": "0.0.2",
  "identifier": "com.gdwhisper.oh-my-llama",
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Oh My Llama",
        "width": 1100,
        "height": 780,
        "minWidth": 450,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: tauri:; connect-src 'self' tauri://localhost; font-src 'self'; frame-src 'none'; base-uri 'self'; form-action 'none'; object-src 'none'; upgrade-insecure-requests;"
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:6060",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  }
}
